{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "python -m pip install -r requirements.txt && camoufox fetch"
    },
    "deploy": {
        "startCommand": "python main.py",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
